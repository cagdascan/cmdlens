{
  "name": "cmdlens",
  "version": "0.1.1",
  "description": "Explain shell commands and generate them from plain English using Codex",
  "type": "module",
  "license": "MIT",
  "author": "Cagdas Can",
  "repository": {
    "type": "git",
    "url": "https://github.com/cagdascan/cmdlens.git"
  },
  "keywords": [
